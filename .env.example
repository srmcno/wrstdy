# Recommended for hosted or externally distributed builds. Point this at a
# server-side endpoint that forwards Messages API requests to Anthropic while
# keeping ANTHROPIC_API_KEY on the server.
#
# VITE_AI_PROXY_URL=https://your-internal-host.example.com/api/ai/messages

# Local/internal direct-browser mode only. If set without VITE_AI_PROXY_URL,
# this key is baked into the built JavaScript/HTML and can be extracted by
# anyone who receives the build artifact.
#
# VITE_ANTHROPIC_KEY=sk-ant-...
