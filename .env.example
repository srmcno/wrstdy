# ── Browser app (Vite build-time variables) ─────────────────────────────────

# Recommended for hosted or externally distributed builds. Point this at the
# AI proxy's messages endpoint (scripts/ai-proxy.js). Use a relative path when
# the proxy also serves the built app (Docker one-container deploy):
#
# VITE_AI_PROXY_URL=/api/ai/messages
# VITE_AI_PROXY_URL=https://your-internal-host.example.com/api/ai/messages

# Local/internal direct-browser mode only (Anthropic only). If set without
# VITE_AI_PROXY_URL, this key is baked into the built JavaScript/HTML and can
# be extracted by anyone who receives the build artifact.
#
# VITE_ANTHROPIC_KEY=sk-ant-...

# Optional geocoding proxy endpoint (scripts/geocode-proxy.js):
# VITE_GEOCODE_ENDPOINT=/api/geocode

# ── AI proxy server (scripts/ai-proxy.js runtime variables) ─────────────────
# Set at least one provider key. Never commit real keys.
#
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
#
# Optional — model allowlists ("id" or "id=Label", comma separated):
# ANTHROPIC_MODELS=claude-opus-4-8=Claude Opus 4.8 (most capable),claude-sonnet-5=Claude Sonnet 5 (balanced),claude-haiku-4-5=Claude Haiku 4.5 (fast)
# OPENAI_MODELS=gpt-5.1=GPT-5.1,gpt-5.1-mini=GPT-5.1 mini (fast)
# AI_DEFAULT_MODEL=claude-opus-4-8
# AI_LIGHT_MODEL=claude-haiku-4-5
#
# Optional — operations:
# AI_PROXY_PORT=8788
# AI_AUTH_TOKEN=shared-access-code-for-staff
# AI_CORS_ORIGIN=https://your-app-host.example.com
# AI_MAX_TOKENS_CAP=8192
# AI_RATE_LIMIT_PER_MIN=30
# AI_UPSTREAM_TIMEOUT_MS=120000
# AI_STATIC_DIR=./dist
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_BASE_URL=https://api.openai.com/v1
